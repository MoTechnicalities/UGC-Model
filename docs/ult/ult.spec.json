{
  "spec_id": "ult_universal_language_tensor_spec",
  "spec_version": "1.1.0",
  "description": "Combined machine-readable ULT package with schema, formal definitions, reasoning algebra, examples, and reversible generator rules.",
  "core_tuple": [
    "family_id",
    "canonical_form",
    "ontology_tags",
    "dimensionality_inference",
    "boundary_condition_classification"
  ],
