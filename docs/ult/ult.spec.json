    "versioning_policy": {
      "breaking_change": "Increment MAJOR when core_tuple fields or schema constraints become incompatible.",
      "non_breaking_change": "Increment MINOR when adding backward-compatible fields or examples.",
      "patch_change": "Increment PATCH for typo fixes or clarifications that do not alter machine behavior."
    }
  },
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.org/schemas/ult.schema.json",
    "title": "ULT - Universal Language Tensor",
    "description": "Strict JSON Schema for the core ULT semantic record.",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "family_id",
      "canonical_form",
      "ontology_tags",
      "dimensionality_inference",
      "boundary_condition_classification"
    ],
    "properties": {
      "family_id": {
        "type": "string",
        "minLength": 1,
        "description": "Semantic equivalence class or relation family identifier."
      },
      "canonical_form": {
        "type": "string",
        "minLength": 1,
        "description": "Normalized predicate skeleton or logical form."
      },
      "ontology_tags": {
        "type": "array",
        "description": "Semantic anchors used for reasoning and cross-domain alignment.",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      },
      "dimensionality_inference": {
        "type": "string",
        "minLength": 1,
        "description": "Semantic domain or manifold in which the meaning is interpreted."
      },
      "boundary_condition_classification": {
        "type": "string",
        "minLength": 1,
        "description": "Constraint, context, or boundary classification for the meaning object."
      }
    }
  },
  "mathematical_definition": {
    "notation": {
      "ult": "ULT(s) = <f, c, Omega, d, b>",
      "family_id": "f in F",
      "canonical_form": "c in C",
      "ontology_tags": "Omega subseteq T and finite",
      "dimensionality_inference": "d in D",
      "boundary_condition_classification": "b in B"
    },
    "sets": {
      "F": "semantic family identifiers",
      "C": "canonical forms",
      "T": "ontology tag vocabulary",
      "D": "semantic domain vocabulary",
      "B": "boundary or context classification vocabulary"
    },
    "formalization": "ULT is an element of F x C x P_fin(T) x D x B with Omega finite and non-empty.",
    "normalization_maps": {
      "family_classifier": "F: Sigma -> F",
      "canonicalizer": "N: Sigma -> C",
      "tagger": "T: Sigma -> P_fin(T)",
      "dimensionality_inferencer": "D: Sigma -> D",
      "boundary_classifier": "B: Sigma -> B"
    },
    "mapping_equation": "ULT(sigma) = <F(sigma), N(sigma), T(sigma), D(sigma), B(sigma)>",
    "equivalence": "sigma1 and sigma2 are semantically equivalent when their normalized ULT tuples are equal or differ only by a lossless surface transform.",
    "invariance": [
      "paraphrase that preserves meaning",
      "translation that preserves semantics",
      "symbolic reformatting that preserves canonical form",
      "register changes that do not alter family, tags, or constraints"
    ],
    "composition": "Compatible ULT records may be composed by concatenating canonical forms and combining compatible ontology tags while preserving traceability."
  },
  "reasoning_algebra": {
    "universe": {
      "single_object": "u = <f, c, Omega, d, b>",
      "components": {
        "family_id": "f in F",
        "canonical_form": "c in C",
        "ontology_tags": "Omega subseteq T and finite",
        "dimensionality_inference": "d in D",
        "boundary_condition_classification": "b in B"
      },
      "carrier_sets": ["single_ult", "finite_set_of_ults"]
    },
    "lattice_requirements": {
      "family_lattice": "(F, <=)",
      "domain_lattice": "(D, <=)",
      "boundary_lattice": "(B, <=)",
      "support_ops": ["LUB", "GLB"]
    },
    "operators": {
      "join": {
        "symbol": "⊔",
        "name": "semantic_generalization",
        "definition": "u1 ⊔ u2 = <LUB(f1,f2), c_star, Omega1 union Omega2, LUB(d1,d2), LUB(b1,b2)>",
        "canonical_form_rules": [
          "if c1 == c2 then c_star = c1",
          "if share_pattern(c1,c2) then c_star = pattern_abstraction(c1,c2)",
          "else c_star = most_general_unifier(c1,c2)"
        ],
        "example": "possess(Mary,lamb) ⊔ possess(John,car) = possess(X,Y)"
      },
      "meet": {
        "symbol": "⊓",
        "name": "semantic_intersection",
        "definition": "u1 ⊓ u2 = <GLB(f1,f2), c_star, Omega1 intersection Omega2, GLB(d1,d2), GLB(b1,b2)>",
        "canonical_form_rules": [
          "if c1 == c2 then c_star = c1",
          "if specializes(c1,c2) then c_star = more_specific(c1,c2)",
          "else c_star = bottom_canonical"
        ],
        "bottom_rule": "if any required component is bottom_inconsistent then result = bottom"
      },
      "entailment": {
        "symbol": "⊢",
        "name": "directional_inclusion",
        "definition": "u1 ⊢ u2 iff family_specificity and canonical_specialization and tag_inclusion and domain_specificity and boundary_strength all hold",
        "conditions": {
          "family": "f1 <= f2",
          "canonical": "specializes_or_instantiates(c1,c2)",
          "tags": "Omega2 subseteq Omega1",
          "domain": "d1 <= d2",
          "boundary": "stronger_or_equal(b1,b2)"
        }
      },
      "contradiction": {
        "symbol": "⊥",
        "name": "incompatibility_detection",
        "predicate": "Contradict(u1,u2)",
        "fires_when": [
          "opposed_ontology_tags",
          "canonical_form_mutual_exclusion",
          "boundary_conflict",
          "dimensionality_clash"
        ],
        "rule": "if Contradict(u1,u2) then (u1 ⊓ u2) = bottom"
      },
      "composition": {
        "symbol": "⨁",
        "name": "narrative_structural_chaining",
        "binary_definition": "ui ⊕ uj = <sequence_family(fi,fj), sequence(ci,cj), Omega_i union Omega_j union {sequence, temporal_order}, LUB(di,dj), compose_boundary(bi,bj)>",
        "fold": "U_star = fold_left(⊕, [u1, u2, ..., un])",
        "notes": [
          "order_sensitive",
          "used_for_plans_narratives_proofs"
        ]
      }
    },
    "algebraic_laws": {
      "join": ["commutative", "associative", "idempotent"],
      "meet": ["commutative", "associative", "idempotent"],
      "lattice_absorption": [
        "u ⊔ (u ⊓ v) = u",
        "u ⊓ (u ⊔ v) = u"
      ],
      "entailment": ["reflexive", "transitive"],
      "contradiction": ["symmetric"],
      "composition": ["associative", "not_commutative"]
    },
    "practical_capabilities": [
      "abstraction_via_join",
      "overlap_and_conflict_analysis_via_meet_and_contradiction",
      "knowledge_propagation_via_entailment",
      "plan_story_argument_construction_via_composition",
      "consistency_validation_for_multi_step_semantics"
    ]
  },
  "generator_rules": {
    "name": "reversible_ult_to_language_generator",
    "deterministic": true,
    "reversible": true,
    "input": [
      "family_id",
      "canonical_form",
      "ontology_tags",
      "dimensionality_inference",
      "boundary_condition_classification"
    ],
    "steps": [
      "Select a realization template from family_id.",
      "Insert canonical_form into the template slot structure.",
      "Project ontology tags into lexical choice hints.",
      "Use dimensionality_inference to choose register and domain vocabulary.",
      "Use boundary_condition_classification to add or suppress contextual qualifiers.",
      "Surface the sentence in the target language or style profile."
    ],
    "reversibility_condition": [
      "slot markers are preserved",
      "canonical predicate order is preserved",
      "stable tag-to-lexeme mappings are preserved",
      "explicit boundary annotations are preserved when requested"
    ],
    "inverse_map": "G_inverse(G(u, L)) = u for supported controlled profiles.",
    "templates": {
      "relation": "{SUBJECT} has {OBJECT}.",
      "event": "{AGENT} {ACTION} {PATIENT}.",
      "conditional": "If {CONDITION}, then {OUTCOME}.",
      "spatial": "{ENTITY_1} is {RELATION} {ENTITY_2}.",
      "symbolic": "{CANONICAL_FORM}"
    },
    "language_rules": [
      "Preserve semantic roles in order.",
      "Translate lexical items from a controlled bilingual lexicon.",
      "Keep named entities unchanged unless transliteration is specified.",
      "Preserve negation, modality, and quantifiers exactly.",
      "Preserve boundary qualifiers when requested."
    ],
    "reverse_reconstruction": [
      "Parse surface syntax into predicate slots.",
      "Recover canonical form.",
      "Reapply the ontology tag inventory.",
      "Infer dimensionality.",
      "Recover boundary classification from explicit markers or defaults."
    ]
  },
